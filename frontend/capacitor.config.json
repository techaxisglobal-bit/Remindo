{
  "appId": "com.techaxisglobal.remindo",
  "appName": "Remindo",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "hostname": "remindo.app",
    "cleartext": false
  },
  "plugins": {
    "GoogleAuth": {
      "scopes": ["profile", "email"],
      "serverClientId": "733914668823-fl25s7gs82c51qu9vgq4prrp2h32qmd0.apps.googleusercontent.com",
      "forceCodeForRefreshToken": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
